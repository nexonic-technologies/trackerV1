{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WorkHub Mobile",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--dart-define-from-file=.env"
            ]
        },
        {
            "name": "WorkHub Web (Port 5050)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--web-port",
                "5050",
                "--dart-define-from-file=.env"
            ]
        }
    ]
}
