{
  "name": "backend",
  "version": "3.1.2",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node --max-old-space-size=4096 --expose-gc --watch server.js",
    "start": "node --max-old-space-size=4096 server.js",
    "dev:monitor": "node --max-old-space-size=4096 --expose-gc --watch server.js",
    "backup": "node -e \"import('./src/services/backupService.js').then(s => s.default.createFullBackup())\"",
    "cron:stats": "node -e \"import('./src/cron/AttendanceCron.js').then(m => // console.log(m.monitor.getStats()))\"",
    "queue:health": "node -e \"import('./src/services/attendanceService.js').then(s => // console.log(s.default.getQueueStats()))\"",
    "db:analyze": "node -e \"import('dotenv').then(d => d.config()); import('./src/Config/ConnectDB.js').then(c => c.default()).then(() => import('./src/services/databaseIndexer.js')).then(s => s.default.analyzeQueryPerformance()).then(() => process.exit(0))\"",
    "db:reindex": "node -e \"import('dotenv').then(d => d.config()); import('./src/Config/ConnectDB.js').then(c => c.default()).then(() => import('./src/services/databaseIndexer.js')).then(s => s.default.createOptimalIndexes()).then(() => process.exit(0))\"",
    "test:security": "node testSecurity.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
