    "@aws-sdk/client-s3": "^3.0.0",
    "archiver": "^7.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-fileupload": "^1.5.0",
    "firebase-admin": "^10.3.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "mongoose": "^8.17.2",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "redis": "^4.6.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.1",
    "ua-parser-js": "^2.0.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
